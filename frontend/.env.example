# -----------------------------------------------------------------------------
# Lex India frontend environment template
# Copy these values into your actual local environment file before running the app.
# -----------------------------------------------------------------------------

# Public app identity
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Lex India

# Backend connectivity
# Keep this pointed at the active FastAPI server when wiring real data.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Frontend behavior flags
# Set to "true" while UI flows are still being built with staged data.
NEXT_PUBLIC_ENABLE_MOCK_DATA=true
NEXT_PUBLIC_DEFAULT_LANGUAGE=english

# Contact / support
NEXT_PUBLIC_SUPPORT_EMAIL=support@lexindia.in

# Optional observability / product services
# Leave blank locally unless the integration is active.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_VERCEL_ENV=
